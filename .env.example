# ScheduleMuseAI — Environment Variables
# Copy to .env.local and fill in values: cp .env.example .env.local
# All variables are REQUIRED unless marked (optional).

# ─── Clerk Authentication ────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ADMIN_USER_IDS=                          # Comma-separated Clerk user IDs with admin access

# Clerk routing (consumed by @clerk/nextjs SDK)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=

# ─── Cloudflare (D1 + KV via REST API) ──────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_KV_NAMESPACE_ID=

# ─── Encryption ─────────────────────────────────────────────────
ENCRYPTION_KEY=                                # 64-char hex string (32 bytes) for AES-256-GCM

# ─── Zoom OAuth ─────────────────────────────────────────────────
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=
ZOOM_WEBHOOK_SECRET_TOKEN=

# ─── Gmail OAuth ────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=

# ─── GoTo Meeting OAuth ─────────────────────────────────────────
GOTOMEETING_CLIENT_ID=
GOTOMEETING_SECRET=
GOTOMEETING_REDIRECT_URI=

# ─── Email (Resend — platform transactional email) ──────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=                             # e.g. noreply@schedulemuseai.com
RESEND_FROM_NAME=                              # e.g. ScheduleMuseAI
